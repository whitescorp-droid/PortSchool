generator client {
  provider = "prisma-client"
  output   = "../src/lib/generated/client"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  fullName  String
  email     String   @unique
  password  String
  grade     String   // Örn: 9, 10, 11, 12
  points    Int      @default(0)
  activities Activity[]
  createdAt DateTime @default(now())
}

model Activity {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  type      String   // Örn: "QUESTION_SOLVED", "LESSON_COMPLETED"
  points    Int
  details   String?  // Örn: Hangi ders/konu olduğu
  createdAt DateTime @default(now())
}
